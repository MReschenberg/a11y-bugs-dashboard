# Read-only Bugzilla API key.
# Create one at: https://bugzilla.mozilla.org/userprefs.cgi?tab=apikey
#
# Copy this file to `.env` (which is gitignored) and paste your key below.
# Optional for local dev: without it you ingest only PUBLIC access bugs;
# with it, security-restricted bugs are included (aggregate-only output — R15).
#
# In CI this is provided as the GitHub Actions secret BUGZILLA_API_KEY instead.
BUGZILLA_API_KEY=
