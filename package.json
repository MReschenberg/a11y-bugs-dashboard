{
  "name": "a11y-bugs-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Living dashboard of Firefox accessibility (access-keyword) bugs from Bugzilla. See planning docs in Obsidian; this repo is the implementation.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ingest": "tsx ingest/run.ts",
    "privacy-scan": "tsx ingest/privacy-scan.ts",
    "audit": "tsx ingest/audit.ts"
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.16"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
